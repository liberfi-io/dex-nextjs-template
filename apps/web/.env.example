# dex-nextjs-template — Environment Variable Reference
# Copy to .env.local and fill in the values marked with <...>.
#
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.

# ── Server-side backend URLs (used in next.config.mjs rewrites) ──────────────
GRAPHQL_SERVER_ENDPOINT=https://backend.liberfi.io/graphql
DEX_AGGREGATOR_URL=https://api.chainstream.io
MEDIA_TRACK_URL=https://api.chainstream.io/api/x-monitor/v1
CHANNELS_URL=https://api.liberfi.io/channel-api/api/v1
PREDICT_URL=https://api.liberfi.io/prediction
PERPETUALS_API_URL=https://api.liberfi.io/staging/perpetuals

# ── Auth0 (server-side, upstream authentication) ─────────────────────────────
DEX_AUTH0_DOMAIN=dex.asia.auth.chainstream.io
DEX_AUTH0_AUDIENCE=https://api.dex.chainstream.io
DEX_AUTH0_CLIENT_ID=<auth0-client-id>
DEX_AUTH0_CLIENT_SECRET=<auth0-client-secret>

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<jwt-secret-min-32-bytes>
JWT_ISSUER=https://auth.liberfi.io
JWT_AUDIENCE=https://app.liberfi.io
JWT_EXPIRES_IN=1000d
JWT_COOKIE_NAME=liberfi-token

# ── Privy ────────────────────────────────────────────────────────────────────
PRIVY_APP_ID=<privy-app-id>
PRIVY_APP_SECRET=<privy-app-secret>
NEXT_PUBLIC_PRIVY_APPID=<privy-app-id>

# ── Client-side public URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_GRAPHQL_ENDPOINT=/graphql
NEXT_PUBLIC_DEX_AGGREGATOR_URL=/dex-api
NEXT_PUBLIC_MEDIA_TRACK_URL=/media-track-api
NEXT_PUBLIC_MEDIA_TRACK_STREAM_URL=wss://realtime-dex.chainstream.io/connection/websocket
NEXT_PUBLIC_CHANNELS_URL=/channel-api
NEXT_PUBLIC_PREDICT_URL=/predict-api
NEXT_PUBLIC_PERPETUALS_API_PATH=/perpetuals-api
NEXT_PUBLIC_PREDICT_WS_URL=wss://api.liberfi.io/prediction/api/v1/ws
NEXT_PUBLIC_AI_COPILOT_URL=https://ai-copilot-api.liberfi.io/api/v1/chat/stream

# ── Client-side public config ───────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_RPC_URL=<solana-rpc-url>
NEXT_PUBLIC_DEFAULT_TOKEN_ADDRESS=6p6xgHyF7AeE6TZkSmFsko444wqoP15icUSqi2jfGiPN
NEXT_PUBLIC_DEFAULT_TOKEN_CHAIN=solana
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_PINATA_GATEWAY=

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_AUTH_TOKEN=<sentry-auth-token>

# ── Local SDK development (uncomment to use local react-sdk source) ─────────
# USE_LOCAL_SDK=true
# LOCAL_SDK_ROOT=../../../react-sdk
