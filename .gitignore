# See http://help.github.com/ignore-files/ for more about ignoring files.

# compiled output
dist
tmp
/out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
/typings
npm-debug.log
yarn-error.log
testem.log
.yarn
.turbo
.history

# System Files
.DS_Store
Thumbs.db

# Environment Files
.env
.env.*
# But always track *.env.example — these are documentation, not secrets.
!.env.example
!apps/**/.env.example
*storybook.log

# SDK link state
.sdk-link-state.json

# Screenshots and temp files
*.png
# Allow committed static assets under apps/web/public to override the
# blanket *.png ignore (avoids accidentally publishing 404s on Vercel).
!apps/web/public/**/*.png
sdk-status-tee.txt

# Cursor IDE
.cursor/

# next.js
.next/
.vercel
